upstream keycloak_upstream {
{% if keycloak_enable_sticky_sessions | default(true) %}
    ip_hash;
{% endif %}
{% for replica_port in keycloak_replica_ports %}
    server 127.0.0.1:{{ replica_port }};
{% endfor %}
    keepalive 32;
}

{% if keycloak_tls_ready | default(false) %}
server {
    listen 80;
    server_name {{ keycloak_server_name_effective }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name {{ keycloak_server_name_effective }};

    ssl_certificate /etc/letsencrypt/live/{{ keycloak_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ keycloak_domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    location / {
        proxy_pass http://keycloak_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_buffer_size 128k;
        proxy_buffers 8 256k;
        proxy_busy_buffers_size 256k;
    }
}
{% else %}
server {
    listen 80;
    server_name {{ keycloak_server_name_effective }};

    location / {
        proxy_pass http://keycloak_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_hide_header Strict-Transport-Security;
        proxy_buffer_size 128k;
        proxy_buffers 8 256k;
        proxy_busy_buffers_size 256k;
    }
}
{% endif %}
